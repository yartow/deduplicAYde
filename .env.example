# Absolute path to the external hard drive mount point
DATA_DIR=/Volumes/External/photos_cleanup

# Optional: override detection thresholds
BLUR_THRESHOLD=100
EDGE_THRESHOLD=0.05
OCR_DENSITY_THRESHOLD=0.001
PHASH_HAMMING_THRESHOLD=10

# Timezone your Google Photos account displays times in (round0 converts
# Takeout sidecar timestamps, which are UTC, to this zone so they match what
# locate_stage.py sees in the UI when staging items)
ACCOUNT_TIMEZONE=Europe/Amsterdam
